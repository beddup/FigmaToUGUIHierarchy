{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "prefab-hierarchy-schema",
  "title": "Prefab Hierarchy JSON Schema",
  "description": "JSON schema for Unity uGUI prefab hierarchy generated from Figma designs",
  "type": "object",
  "required": [
    "nodeId",
    "nodeName",
    "gameObjectCategory",
    "gameObjectName",
    "isButton",
    "horizontal_alignment",
    "vertical_alignment",
    "children"
  ],
  "properties": {
    "nodeId": {
      "type": "string",
      "description": "Unique identifier from Figma node (e.g., '4590:9919')"
    },
    "nodeName": {
      "type": "string",
      "description": "Original name from Figma node (e.g., '排行榜_结算无奖励')"
    },
    "gameObjectCategory": {
      "type": "string",
      "enum": [
        "container",
        "image",
        "text",
        "color"
      ],
      "description": "Unity GameObject category"
    },
    "gameObjectName": {
      "type": "string",
      "description": "Meaningful and descriptive name for the GameObject in PascalCase (e.g., 'LeaderboardSettlementNoReward')"
    },
    "isButton": {
      "type": "boolean",
      "description": "Whether this GameObject should have a Button component attached"
    },
    "horizontal_alignment": {
      "type": "string",
      "enum": [
        "left",
        "center",
        "right",
        "stretch"
      ],
      "description": "Responsive horizontal alignment for Unity layout adaptation"
    },
    "vertical_alignment": {
      "type": "string",
      "enum": [
        "top",
        "center",
        "bottom",
        "stretch"
      ],
      "description": "Responsive vertical alignment for Unity layout adaptation"
    },
    "image_type": {
      "type": "string",
      "enum": ["simple", "sliced", "tiled"],
      "description": "Image fill type. Required when gameObjectCategory is 'image'. simple: basic fill, sliced: 9-slice, tiled: tiled fill"
    },
    "text_rect": {
      "type": "object",
      "description": "Inferred runtime text display rectangle in the same global coordinate space as simplified Figma flatNodes[].bounds. Required when gameObjectCategory is 'text'.",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": {
          "type": "integer",
          "description": "Global Figma-space x coordinate of the inferred text display rectangle"
        },
        "y": {
          "type": "integer",
          "description": "Global Figma-space y coordinate of the inferred text display rectangle"
        },
        "width": {
          "type": "integer",
          "minimum": 0,
          "description": "Inferred runtime text display width"
        },
        "height": {
          "type": "integer",
          "minimum": 0,
          "description": "Inferred runtime text display height"
        }
      },
      "additionalProperties": false
    },
    "text_alignment": {
      "type": "object",
      "description": "Inferred text rendering alignment. Required when gameObjectCategory is 'text'.",
      "required": ["horizontal", "vertical"],
      "properties": {
        "horizontal": {
          "type": "string",
          "enum": ["left", "center", "right"]
        },
        "vertical": {
          "type": "string",
          "enum": ["top", "middle", "bottom"]
        }
      },
      "additionalProperties": false
    },
    "children": {
      "type": "array",
      "description": "Child GameObjects in the hierarchy",
      "items": {
        "$ref": "#"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "gameObjectCategory": { "const": "image" }
        },
        "required": ["gameObjectCategory"]
      },
      "then": {
        "required": ["image_type"]
      }
    },
    {
      "if": {
        "properties": {
          "gameObjectCategory": { "const": "text" }
        },
        "required": ["gameObjectCategory"]
      },
      "then": {
        "required": ["text_rect", "text_alignment"]
      }
    }
  ],
  "definitions": {},
  "examples": [
    {
      "nodeId": "4590:9919",
      "nodeName": "排行榜_结算无奖励",
      "gameObjectCategory": "container",
      "gameObjectName": "LeaderboardSettlementNoReward",
      "isButton": false,
      "horizontal_alignment": "center",
      "vertical_alignment": "center",
      "children": [
        {
          "nodeId": "4590:9921",
          "nodeName": "Title",
          "gameObjectCategory": "text",
          "gameObjectName": "TitleText",
          "isButton": false,
          "horizontal_alignment": "center",
          "vertical_alignment": "top",
          "text_rect": {
            "x": 240,
            "y": 120,
            "width": 600,
            "height": 64
          },
          "text_alignment": {
            "horizontal": "center",
            "vertical": "middle"
          },
          "children": []
        }
      ]
    }
  ]
}
